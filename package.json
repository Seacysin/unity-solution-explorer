{
  "name": "unity-solution-explorer",
  "displayName": "Unity Solution Explorer",
  "description": "Browse Unity .sln/.csproj in the sidebar; ignores non-Unity editor files; drag-drop move within assembly, open in editor/Chat; supports .cs/.shader/.xml and right-click add/rename/delete. 在侧边栏按 .sln/.csproj 展示 Unity 解决方案与程序集结构，支持树内拖拽移动（确认后）、拖入编辑器/聊天、多选拖拽，以及 .cs/.shader/.xml/.txt/.json、右键新建/重命名/删除、排除项目配置",
  "version": "1.1.4",
  "publisher": "Seacysin",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:**/*.sln"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "unitySolutionExplorer",
          "title": "Unity Solution Explorer",
          "icon": "resources/icon.png"
        }
      ]
    },
    "views": {
      "unitySolutionExplorer": [
        {
          "id": "unitySolutionExplorerView",
          "name": "Unity Solution Explorer"
        }
      ]
    },
    "commands": [
      {
        "command": "unitySolutionExplorer.refresh",
        "title": "刷新解决方案",
        "icon": "$(refresh)"
      },
      {
        "command": "unitySolutionExplorer.newFile",
        "title": "新建文件"
      },
      {
        "command": "unitySolutionExplorer.renameFolder",
        "title": "重命名文件夹"
      },
      {
        "command": "unitySolutionExplorer.newFolder",
        "title": "新建文件夹"
      },
      {
        "command": "unitySolutionExplorer.deleteFolder",
        "title": "删除文件夹"
      },
      {
        "command": "unitySolutionExplorer.revealFolderInExplorer",
        "title": "在资源管理器中打开文件夹"
      },
      {
        "command": "unitySolutionExplorer.copyFolderPath",
        "title": "复制绝对路径"
      },
      {
        "command": "unitySolutionExplorer.renameFile",
        "title": "重命名文件"
      },
      {
        "command": "unitySolutionExplorer.deleteFile",
        "title": "删除文件"
      },
      {
        "command": "unitySolutionExplorer.revealFileInExplorer",
        "title": "在资源管理器中打开所在文件夹"
      },
      {
        "command": "unitySolutionExplorer.copyFilePath",
        "title": "复制绝对路径"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "unitySolutionExplorer.refresh",
          "when": "view == unitySolutionExplorerView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "unitySolutionExplorer.newFile",
          "when": "view == unitySolutionExplorerView && viewItem == folder",
          "group": "1_new"
        },
        {
          "command": "unitySolutionExplorer.newFolder",
          "when": "view == unitySolutionExplorerView && viewItem == folder",
          "group": "1_new"
        },
        {
          "command": "unitySolutionExplorer.renameFolder",
          "when": "view == unitySolutionExplorerView && viewItem == folder",
          "group": "2_edit"
        },
        {
          "command": "unitySolutionExplorer.deleteFolder",
          "when": "view == unitySolutionExplorerView && viewItem == folder",
          "group": "2_edit"
        },
        {
          "command": "unitySolutionExplorer.revealFolderInExplorer",
          "when": "view == unitySolutionExplorerView && viewItem == folder",
          "group": "3_open"
        },
        {
          "command": "unitySolutionExplorer.copyFolderPath",
          "when": "view == unitySolutionExplorerView && viewItem == folder",
          "group": "3_open"
        },
        {
          "command": "unitySolutionExplorer.renameFile",
          "when": "view == unitySolutionExplorerView && viewItem == file",
          "group": "2_edit"
        },
        {
          "command": "unitySolutionExplorer.deleteFile",
          "when": "view == unitySolutionExplorerView && viewItem == file",
          "group": "2_edit"
        },
        {
          "command": "unitySolutionExplorer.revealFileInExplorer",
          "when": "view == unitySolutionExplorerView && viewItem == file",
          "group": "3_open"
        },
        {
          "command": "unitySolutionExplorer.copyFilePath",
          "when": "view == unitySolutionExplorerView && viewItem == file",
          "group": "3_open"
        }
      ]
    },
    "configuration": {
      "title": "Unity Solution Explorer",
      "properties": {
        "unitySolutionExplorer.excludeProjects": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "不在 Solution Explorer 中显示的项目（程序集）名称列表，可与 .vscode/unity-solution-explorer.json 合并"
        },
        "unitySolutionExplorer.additionalFileExtensions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "除内置 (.cs/.shader/.xml/.txt/.json) 外，树中要展示的额外扩展名，如 [\".dll\"]。可与工作区 .vscode/unity-solution-explorer.json 中的 additionalFileExtensions 合并"
        },
        "unitySolutionExplorer.extraSolutionFolders": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "在解决方案根额外展示的目录（相对工作区根），如 [\".cursor\", \".claude\"]。推荐写在项目 .vscode/settings.json"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.74.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^3.0.0"
  },
  "license": "MIT",
  "icon": "resources/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Seacysin/unity-solution-explorer.git"
  },
  "homepage": "https://github.com/Seacysin/unity-solution-explorer#readme",
  "bugs": {
    "url": "https://github.com/Seacysin/unity-solution-explorer/issues"
  }
}